# PKGBUILD - ZelixOS GUI Installer
pkgname=zelixins
pkgver=1.04
pkgrel=2
pkgdesc="Official graphical installer for ZelixOS"
arch=('any')
url="https://github.com/ZelixOS/zelixins"
license=('GPL')
depends=('python' 'python-pyqt6' 'archinstall')

source=("myself.py"
        "zelix-installer.desktop"
        "zelix_post_install.sh")
sha256sums=('SKIP'
            'SKIP'
            'SKIP')

package() {
    # 1. Gerekli sistem dizinlerini oluştur
    install -d "$pkgdir/usr/share/zelixins"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/bin"

    # 2. Tüm kaynak dosyalarını /usr/share/zelixins altına kopyala
    cp -rp "$startdir/myself.py" "$startdir/icons" "$startdir/slides" "$startdir/zelixdeps" "$startdir/zelix_post_install.sh" "$pkgdir/usr/share/zelixins/"

    # 3. .desktop dosyasını uygulamalar menüsüne kopyala
    install -m755 "$startdir/zelix-installer.desktop" "$pkgdir/usr/share/applications/zelix-installer.desktop"

    # 4. Terminalden çalıştırma kolaylığı (Symlink)
    ln -s /usr/share/zelixins/myself.py "$pkgdir/usr/bin/zelix-installer"
    
    # Çalıştırma yetkilerini garantile
    chmod +x "$pkgdir/usr/share/zelixins/myself.py"
    chmod +x "$pkgdir/usr/share/zelixins/zelix_post_install.sh"
}
